  <property name="styleSheet">
   <string notr="true">/* ============================================================ */
/* OPTICAL - GLOBAL SURFACES                                    */
/* ============================================================ */

QWidget#wgOptical {
    background-color: #3a3a3a;
    border: none;
}

QFrame {
    border: none;
}

QFrame#frame_leftWindow {
    background-color: #3a3a3a;
}

QWidget#widget_headerFrame {
    background-color: #090909;
    border: none;
}

QWidget#widget_sectionHeadings {
    background-color: #181818;
}

QWidget#widget_exportPanel {
    background-color: #181818;
}

/* ============================================================ */
/* BRANDING / TOP HEADER                                        */
/* ============================================================ */

QLabel#label_optical {
    font-weight: 600;
    font-size: 40pt;
    color: #ededed;
    background: transparent;
}

QLabel#label_version {
    font-size: 10pt;
    color: #bdbdbd;
    background: transparent;
}

/* ============================================================ */
/* SECTION HEADINGS / TITLES                                    */
/* ============================================================ */

QLabel[isHeader=&quot;true&quot;] {
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

QFrame[isHeaderStrip=&quot;true&quot;] {
    background-color: #262626;
    border: none;
}

QLabel[isFolderTitle=&quot;true&quot;] {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

/* ============================================================ */
/* TARGET FOLDER PANEL                                          */
/* ============================================================ */

QFrame#frame_targetFolder,
QLabel#title_targetFolder,
QWidget#page_emptyFolderList {
    background-color: #2f2f2f;
}

/* Frame now owns the full outline */
QFrame#frame_inputTargetFolder {
    background-color: #d6d6d6;
    border: 2px solid #bcbcbc;
    border-radius: 2px;
    padding: 0px;
}

QFrame#frame_inputTargetFolder[pathState=&quot;missing&quot;] {
    border: 2px solid #d96c6c;
}

QFrame#frame_inputTargetFolder[pathState=&quot;valid&quot;] {
    border: 2px solid #5fcf8f;
}

/* LineEdit has no border now */
QLineEdit#input_targetFolder {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: none;
    padding: 0px 6px;
}

/* Button has no border now */
QPushButton#btn_browseTargetFolder {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    padding: 0px;

    min-width: 26px;
    max-width: 26px;
    min-height: 20px;
    max-height: 20px;
}

QPushButton#btn_browseTargetFolder:hover {
    background-color: #ffc533;
}

QPushButton#btn_browseTargetFolder:pressed {
    background-color: #d89c00;
}

/* ============================================================ */
/* FOLDER LIST PANEL                                            */
/* ============================================================ */

QWidget#page_folderList {
    background-color: #2f2f2f;
    border: none;
}

QLabel#label_titleFolders {
    background-color: #2a2a2a;
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    padding: 6px 10px;
}

QListWidget#list_folders,
QListWidget#list_folders QAbstractItemView {
    background-color: #2f2f2f;
    color: #ededed;
    border: none;
    outline: none;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 600;
}

QListWidget#list_folders::item {
    padding: 6px 10px;
    margin: 0px;
    border: none;
}

QListWidget#list_folders::item:hover {
    background-color: #222222;
}

QListWidget#list_folders::item:selected {
    background: transparent;
    color: #f0b000;
}

/* ============================================================ */
/* EMPTY STATE CARDS                                            */
/* ============================================================ */

QFrame#frame_previewEmptyCard {
    background-color: #2a2a2a;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 20px;
}

QLabel#label_previewEmptyTitle,
QLabel#label_listEmptyTitle {
    color: #d8a106;
    font-size: 13pt;
    font-weight: 600;
    background: transparent;
}

QLabel#label_previewEmptyDetail,
QLabel#label_listEmptyDetail {
    color: #8a8a8a;
    font-size: 10pt;
    background: transparent;
}

/* ============================================================ */
/* IMAGE PREVIEW / TEXT ENTRY                                   */
/* ============================================================ */

QWidget#row_textEdit {
    background-color: #090909;
}

QLineEdit#lineEdit_textInput {
    background-color: #090909;
    color: white;
    border: none;
    outline: none;
    font: 40pt &quot;Consolas&quot;;
}

QLineEdit#lineEdit_textInput:focus {
    border: none;
    outline: none;
}

/* ============================================================ */
/* PRIMARY ACTION BUTTONS                                       */
/* ============================================================ */

QPushButton#btn_autoRun,
QPushButton#btn_renameFolders {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-radius: 3px;
    padding: 4px 10px;
    font-weight: 600;
}

QPushButton#btn_autoRun:hover,
QPushButton#btn_renameFolders:hover {
    background-color: #ffc533;
}

QPushButton#btn_autoRun:pressed,
QPushButton#btn_renameFolders:pressed {
    background-color: #d89c00;
}

/* ============================================================ */
/* CONFIRM / IGNORE BUTTONS                                     */
/* ============================================================ */

QPushButton#btn_confirm {
    background-color: #2E7D32;
    color: #0a0a0a;
    border: none;
    border-radius: 4px;
    padding: 8px 18px;
    min-height: 34px;
    font-weight: 600;
}

QPushButton#btn_confirm:hover {
    background-color: #379c3d;
}

QPushButton#btn_confirm:pressed {
    background-color: #1B5E20;
}

QPushButton#btn_ignore {
    background-color: #C62828;
    color: #0a0a0a;
    border: none;
    border-radius: 4px;
    padding: 8px 18px;
    min-height: 34px;
    font-weight: 600;
}

QPushButton#btn_ignore:hover {
    background-color: #e03a3a;
}

QPushButton#btn_ignore:pressed {
    background-color: #8E1C1C;
}

/* ============================================================ */
/* IMAGE VIEWER                                                 */
/* ============================================================ */

QWidget#page_previewImage,
QWidget#previewStage,
QWidget#previewCanvas,
QGraphicsView#imageView {
    background-color: #3a3a3a;
    border: none;
}

QLabel#label_originalFolderName {
    background-color: rgba(9, 9, 9, 220);
    color: #ededed;
    padding: 8px 14px;
    font-size: 12pt;
    font-weight: 700;
    border-radius: 4px;
}

QListWidget#list_folders {
    background-color: #2f2f2f;
    border: none;
    outline: none;
    padding: 0px;
}

QListWidget#list_folders::item {
    border: none;
    margin: 0px;
    padding: 0px;
}

QListWidget#list_folders QWidget {
    background: transparent;
}

QListWidget#list_folders QLabel {
    background: transparent;
}

QScrollBar:vertical {
    background: #1f1f1f;
    width: 12px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background: #5a5a5a;
    min-height: 24px;
    border-radius: 3px;
}

QScrollBar::handle:vertical:hover {
    background: #707070;
}

QScrollBar::handle:vertical:pressed {
    background: #d8a106;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    background: none;
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: #1f1f1f;
}

QScrollBar:horizontal {
    background: #1f1f1f;
    height: 12px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:horizontal {
    background: #5a5a5a;
    min-width: 24px;
    border-radius: 3px;
}

QScrollBar::handle:horizontal:hover {
    background: #707070;
}

QScrollBar::handle:horizontal:pressed {
    background: #d8a106;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    background: none;
    width: 0px;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: #1f1f1f;
}

QListWidget#thumbnailStrip QScrollBar:horizontal {
    background: #141414;
    height: 12px;
    border-top: 1px solid #2a2a2a;
}

QListWidget#thumbnailStrip QScrollBar::handle:horizontal {
    background: #4f4f4f;
    min-width: 30px;
    border-radius: 3px;
}

QListWidget#thumbnailStrip QScrollBar::handle:horizontal:hover {
    background: #666666;
}

QListWidget#thumbnailStrip QScrollBar::handle:horizontal:pressed {
    background: #c99700;
}</string>
